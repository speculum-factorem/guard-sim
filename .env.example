# Скопируйте в .env: cp .env.example .env
# Секрет для подписи JWT (HS256). Не коммитьте .env в git.
# Минимум ~32 символа; для продакшена используйте криптостойкую случайную строку.
GUARDSIM_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars-utf8

# Порт на хосте для веб-интерфейса (nginx внутри слушает 80). По умолчанию 8080.
# Раскомментируйте и поставьте 80, если хотите открывать http://localhost без суффикса порта
# и на машине ничего не слушает :80.
# GUARDSIM_WEB_PORT=80
